{
  "name": "agents-memory",
  "version": "1.1.0",
  "description": "Universal semantic memory layer for AI CLI tools. Remembers everything, forgets nothing.",
  "main": "src/cli.js",
  "bin": {
    "agents-memory": "src/cli.js",
    "am": "src/cli.js",
    "scm": "src/cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "prepack": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; true",
    "test": "node src/cli.js --help"
  },
  "files": [
    "src/",
    "skill/",
    "scripts/",
    "!scripts/__pycache__/",
    "!**/__pycache__/",
    "config/",
    "docs/AGENTS.md",
    "README.md",
    "SKILL.md",
    "requirements.txt"
  ],
  "keywords": [
    "ai",
    "memory",
    "semantic-search",
    "chroma",
    "openclaw",
    "claude-code",
    "gemini-cli",
    "context-overflow"
  ],
  "author": "cahcoder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cahcoder/agents-memory.git"
  },
  "bugs": {
    "url": "https://github.com/cahcoder/agents-memory/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "ora": "^5.4.1"
  }
}
